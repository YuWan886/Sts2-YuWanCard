<Project>
  <UsingTask TaskName="GenerateBaseLibVersionTask" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <OutputPath ParameterType="System.String" Required="true" />
      <Version ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
        var content = $@"// Auto-generated by MSBuild. Do not edit manually.
// Generated at: {DateTime.Now:yyyy-MM-dd HH:mm:ss}

namespace YuWanCard.Utils;

public static class BaseLibVersion
{{
    public const string Version = ""{Version}"";
}}
";
        File.WriteAllText(OutputPath, content);
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="GenerateBaseLibVersionFile" BeforeTargets="BeforeCompile">
    <PropertyGroup>
      <BaseLibVersionFile>$(MSBuildProjectDirectory)\YuWanCardCode\Utils\BaseLibVersion.cs</BaseLibVersionFile>
    </PropertyGroup>
    
    <ItemGroup>
      <BaseLibPackageReference Include="@(PackageReference)" Condition="'%(Identity)' == 'Alchyr.Sts2.BaseLib'" />
    </ItemGroup>
    
    <PropertyGroup>
      <CurrentBaseLibVersion>@(BaseLibPackageReference->'%(Version)')</CurrentBaseLibVersion>
    </PropertyGroup>
    
    <MakeDir Directories="$(MSBuildProjectDirectory)\YuWanCardCode\Utils" Condition="!Exists('$(MSBuildProjectDirectory)\YuWanCardCode\Utils')" />
    
    <GenerateBaseLibVersionTask OutputPath="$(BaseLibVersionFile)" Version="$(CurrentBaseLibVersion)" />
    
    <Message Text="Generated BaseLibVersion.cs with version: $(CurrentBaseLibVersion)" Importance="high" />
  </Target>
</Project>
